<%= form_with url: settings_path(tab: "filters"), method: :patch do |form| %>
  <div class="mb-4">
    <h2 class="subheading">Filters</h2>
    <p class="text-sm text-muted mt-1">Choose which filter is applied first whenever you open a list.</p>
  </div>

  <div class="space-y-5">
    <%=
      render "settings/radio_group",
      form:,
      field: :job_leads_filter,
      label: "Default Job Leads Filter",
      help_text: "Which leads you see first when you open <span class='font-semibold text-light'>Job Leads</span>.",
      options: [
        option("all", icon: "layers"),
        option("active", icon: "check-circle"),
        option("archived", icon: "archive")
      ]
    %>

    <%=
      render "settings/radio_group",
      form:,
      field: :interviews_filter,
      label: "Default Interviews Filter",
      help_text: "Which interviews you see first when you open <span class='font-semibold text-light'>Interviews</span>.",
      options: [
        option("all", icon: "layers"),
        option("upcoming", icon: "calendar"),
        option("completed", icon: "check-circle"),
      ]
    %>

    <%=
      render "settings/radio_group",
      form:,
      field: :notes_filter,
      label: "Default Notes Filter",
      help_text: "Which notes you see first when you open <span class='font-semibold text-light'>Notes</span>.",
      options: [
        option("all", icon: "layers"),
        option("active", icon: "check-circle"),
        option("archived", icon: "archive")
      ]
    %>
  </div>

  <div class="mt-8 pt-4 border-t border-neutral-200 dark:border-neutral-800">
    <%= form.submit "Save Filters", class: "btn btn-primary w-full sm:w-auto" %>
  </div>
<% end %>
