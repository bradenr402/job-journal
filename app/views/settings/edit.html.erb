<% content_for :title, "Settings" %>

<%
  tabs = [
    { id: "goals", label: "Goals", icon: "goal" },
    { id: "filters", label: "Filters", icon: "filter" },
    { id: "appearance", label: "Appearance", icon: "brush" },
    { id: "follow_ups", label: "Follow-Ups", icon: "calendar" },
    { id: "auto_archiving", label: "Auto-Archiving", icon: "archive" },
    { id: "danger_zone", label: "Danger Zone", icon: "alert-triangle", destructive: true }
  ]
%>

<div class="sm:w-7/8 w-full mx-auto">
  <div class="mb-4 flex flex-wrap gap-2 items-center justify-between">
    <%= link_to dashboard_path, class: "btn btn-sm btn-secondary btn-muted gap-1.5 [view-transition-name:back-btn]" do %>
      <%= icon "arrow-left", class: "size-3.5 shrink-0" %>
      <span>Back Home</span>
    <% end %>
  </div>

  <div class="mb-4">
    <h2 class="heading">Settings</h2>
    <p class="text-sm text-muted mt-1">Personalize how JobJournal works for you.</p>
  </div>

  <div
    class="md:flex md:gap-6"
    data-controller="tabs"
    data-tabs-active-value="<%= @active_tab %>"
  >
    <div class="max-md:-mx-4 max-md:mb-6 max-md:py-1.5 max-md:bg-neutral-100/80 max-md:dark:bg-neutral-900/60 md:w-52 md:shrink-0 md:border-r md:border-neutral-200 md:dark:border-neutral-800 md:pr-4">
      <div
        role="tablist"
        aria-label="Settings sections"
        class="tab-link-list anchor-highlight-alt md:anchor-highlight"
        data-action="keydown->tabs#navigate"
      >
        <% tabs.each do |tab| %>
          <% tab_id = tab[:id] %>
          <% active = @active_tab == tab_id %>
          <% tab_icon = tab[:icon] %>

          <button
            type="button"
            id="tab-<%= tab_id %>"
            role="tab"
            aria-controls="panel-<%= tab_id %>"
            aria-selected="<%= active %>"
            tabindex="<%= active ? 0 : -1 %>"
            class="anchor shrink-0 max-md:px-px md:py-px md:w-full md:text-left"
            data-tabs-target="tab"
            data-tabs-id="<%= tab_id %>"
            data-action="tabs#select"
          >
            <span class="tab-link <%= "tab-link-destructive" if tab[:destructive] %>">
              <%= icon tab_icon, class: "tab-link-icon-unselected size-4 shrink-0" %>
              <%= icon "#{tab_icon}-filled", class: "tab-link-icon-selected size-4 shrink-0" %>
              <span><%= tab[:label] %></span>
            </span>
          </button>
        <% end %>
      </div>
    </div>

    <div class="min-w-0 flex-1">
      <% tabs.each do |tab| %>
        <% tab_id = tab[:id] %>
        <div
          id="panel-<%= tab_id %>"
          role="tabpanel"
          aria-labelledby="tab-<%= tab_id %>"
          class="<%= "hidden" unless @active_tab == tab_id %>"
          data-tabs-target="panel"
          data-tabs-id="<%= tab_id %>"
        >
          <%= render "settings/#{tab_id}" %>
        </div>
      <% end %>
    </div>
  </div>
</div>
