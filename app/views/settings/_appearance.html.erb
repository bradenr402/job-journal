<%= form_with url: settings_path(tab: "appearance"), method: :patch do |form| %>
  <div class="mb-4">
    <h2 class="subheading">Appearance Preferences</h2>
    <p class="text-sm text-muted">Arrange each section in a multi-column grid, single-column list, or minimal compact layout.</p>
    <p class="text-xs text-muted mt-1">On smaller screens, everything appears in a single column.</p>
  </div>

  <div class="space-y-5">
    <% display_options = options("grid", "list") + [ option("minimal", icon: "menu") ] %>

    <%= render "settings/radio_group", form:, setting_path: %i[layouts job_leads], options: display_options %>
    <%= render "settings/radio_group", form:, setting_path: %i[layouts interviews], options: display_options %>
    <%= render "settings/radio_group", form:, setting_path: %i[layouts notes], options: display_options %>
  </div>

  <div class="mt-8 pt-4 border-t border-neutral-200 dark:border-neutral-800">
    <%= form.submit "Save Appearance", class: "btn btn-primary w-full sm:w-auto" %>
  </div>
<% end %>
