<%= form_with url: settings_path(tab: "goals"), method: :patch do |form| %>
  <div class="mb-4">
    <h2 class="subheading">Goals</h2>
    <p class="text-sm text-muted mt-1">Set weekly targets to keep your search on track.</p>
  </div>

  <div class="space-y-5">
    <div>
      <%= form.label :weekly_application_goal, "Weekly Application Goal", class: "form-label" %>
      <div class="form-number-frame" data-controller="number-field">
        <button type="button" class="form-number-decrement">
          <%= icon "minus", class: "size-4 shrink-0" %>
        </button>

        <%= form.number_field :weekly_application_goal, value: @settings[:weekly_application_goal], min: 0, class: "form-number", data: { number_field_target: "input" } %>

        <button type="button" class="form-number-increment">
          <%= icon "plus", class: "size-4 shrink-0" %>
        </button>
      </div>
      <p class="text-xs text-muted mt-1">How many applications you aim to submit each week. Your progress appears on your home page.</p>
    </div>
  </div>

  <div class="mt-8 pt-4 border-t border-neutral-200 dark:border-neutral-800">
    <%= form.submit "Save Goals", class: "btn btn-primary w-full sm:w-auto" %>
  </div>
<% end %>
