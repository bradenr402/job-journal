<%= form_with url: settings_path(tab: "follow_ups"), method: :patch do |form| %>
  <div class="mb-4">
    <h2 class="subheading">Follow-Up Suggestions</h2>
    <p class="text-sm text-muted mt-1">Decide when JobJournal nudges you to follow up on leads, applications, and interviews.</p>
  </div>

  <div class="space-y-5">
    <div>
      <%= form.label :job_lead_stale_after_days, "Days Until a Lead Goes Stale", class: "form-label" %>
      <div class="form-number-frame" data-controller="number-field">
        <button type="button" class="form-number-decrement">
          <%= icon "minus", class: "size-4 shrink-0" %>
        </button>

        <%= form.number_field :job_lead_stale_after_days, value: @settings[:job_lead_stale_after_days], min: 1, class: "form-number", data: { number_field_target: "input" } %>

        <button type="button" class="form-number-increment">
          <%= icon "plus", class: "size-4 shrink-0" %>
        </button>
      </div>
      <p class="text-xs text-muted mt-1">If you haven&#8217;t applied to a saved lead within this many days, it&#8217;s considered stale and a reminder appears on your home page.</p>
    </div>

    <div>
      <%= form.label :application_follow_up_days, "Days Before an Application Follow-Up", class: "form-label" %>
      <div class="form-number-frame" data-controller="number-field">
        <button type="button" class="form-number-decrement">
          <%= icon "minus", class: "size-4 shrink-0" %>
        </button>

        <%= form.number_field :application_follow_up_days, value: @settings[:application_follow_up_days], min: 1, class: "form-number", data: { number_field_target: "input" } %>

        <button type="button" class="form-number-increment">
          <%= icon "plus", class: "size-4 shrink-0" %>
        </button>
      </div>
      <p class="text-xs text-muted mt-1">After you apply, you&#8217;ll be reminded to follow up once this many days have passed.</p>
    </div>

    <div>
      <%= form.label :interview_follow_up_days, "Days Before an Interview Follow-Up", class: "form-label" %>
      <div class="form-number-frame" data-controller="number-field">
        <button type="button" class="form-number-decrement">
          <%= icon "minus", class: "size-4 shrink-0" %>
        </button>

        <%= form.number_field :interview_follow_up_days, value: @settings[:interview_follow_up_days], min: 1, class: "form-number", data: { number_field_target: "input" } %>

        <button type="button" class="form-number-increment">
          <%= icon "plus", class: "size-4 shrink-0" %>
        </button>
      </div>
      <p class="text-xs text-muted mt-1">After an interview, you&#8217;ll be reminded to send a thank-you or follow-up once this many days have passed.</p>
    </div>

    <div>
      <%= form.label :suggest_follow_up_days, "Days to Keep Suggestions Visible", class: "form-label" %>
      <div class="form-number-frame" data-controller="number-field">
        <button type="button" class="form-number-decrement">
          <%= icon "minus", class: "size-4 shrink-0" %>
        </button>

        <%= form.number_field :suggest_follow_up_days, value: @settings[:suggest_follow_up_days], min: 1, class: "form-number", data: { number_field_target: "input" } %>

        <button type="button" class="form-number-increment">
          <%= icon "plus", class: "size-4 shrink-0" %>
        </button>
      </div>
      <p class="text-xs text-muted mt-1">Each suggestion stays on your home page for this many days, then disappears on its own.</p>
    </div>
  </div>

  <div class="mt-8 pt-4 border-t border-neutral-200 dark:border-neutral-800">
    <%= form.submit "Save Follow-Ups", class: "btn btn-primary w-full sm:w-auto" %>
  </div>
<% end %>
