<script>
  // Detect iOS/macOS Safari and selectively disable the buggy native VT engine
  if (navigator.userAgent.includes('Safari') && !navigator.userAgent.includes('Chrome') && !navigator.userAgent.includes('CriOS')) {
    if (window.document.startViewTransition) {
      Object.defineProperty(window.document, 'startViewTransition', {
        value: undefined,
        writable: true,
        configurable: true
      });
    }
  }
</script>

<title><%= page_title %></title>
<meta name="viewport" content="width=device-width,initial-scale=1">

<%= csrf_meta_tags %>
<%= csp_meta_tag %>

<%= yield :head %>

<!-- PWA tags -->
<%= tag.link rel: 'manifest', href: pwa_manifest_path(format: :json) %>
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
<meta name="apple-mobile-web-app-title" content="JobJournal">

<%= favicon_link_tag 'icon.png', rel: 'icon', type: 'image/png' %>

<link rel="icon" href="/assets/icon.png" type="image/png">
<link rel="icon" href="/assets/icon.svg" type="image/svg+xml">
<link rel="apple-touch-icon" href="/assets/icon.png">

<%# Includes all stylesheet files in app/assets/stylesheets %>
<%= stylesheet_link_tag :app, 'data-turbo-track': 'reload' %>
<%= javascript_importmap_tags %>

<meta name="view-transition" content="same-origin" />

<meta name="theme-color" content="#ffffff" media="(prefers-color-scheme: light)">
<meta name="theme-color" content="#0a0a0a" media="(prefers-color-scheme: dark)">
