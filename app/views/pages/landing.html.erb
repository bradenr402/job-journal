<% content_for(:title) { 'JobJournal · Your Personal Job Search HQ' } %>

<%# ─── NAV ─── %>
<nav class="fixed top-0 inset-x-0 z-50 bg-white/80 dark:bg-neutral-950/80 backdrop-blur-xl border-b border-neutral-200/60 dark:border-neutral-800/40">
  <div class="max-w-6xl mx-auto px-6 h-16 flex items-center justify-between">
    <%= link_to root_path, class: 'flex items-center gap-1.5 text-primary-600' do %>
      <%= inline_svg_tag 'icons/note-filled.svg', class: 'size-6 shrink-0' %>
      <span class="text-xl font-extrabold tracking-tight">JobJournal</span>
    <% end %>

    <div class="flex items-center gap-3">
      <% if authenticated? %>
        <%= link_to dashboard_path, data: { turbo: false }, class: 'btn btn-primary' do %>
          <span>Home</span>
          <%= inline_svg_tag 'icons/arrow-right.svg', class: 'size-4 shrink-0' %>
        <% end %>
      <% else %>
        <%= link_to 'Sign In', new_session_path, class: 'btn btn-transparent' %>
        <%= link_to 'Sign Up Free', new_registrations_path, class: 'btn btn-primary' %>
      <% end %>
    </div>
  </div>
</nav>

<%# ─── HERO ─── %>
<section class="pt-36 md:pt-44 pb-20 md:pb-28 px-6">
  <div class="max-w-4xl mx-auto text-center">
    <h1 class="text-[clamp(2.75rem,6vw,5rem)] font-extrabold tracking-tight text-neutral-900 dark:text-neutral-100 leading-[1.08] text-balance">
      Your personal job<br class="hidden sm:block"> search HQ.
    </h1>

    <p class="mt-6 text-[clamp(1.05rem,1.5vw,1.25rem)] text-light max-w-2xl mx-auto text-pretty leading-relaxed">
      Track every lead, application, and interview in one place. No more messy spreadsheets.
    </p>

    <div class="mt-10 flex flex-wrap items-center justify-center gap-4">
      <% if authenticated? %>
        <%= link_to dashboard_path, data: { turbo: false }, class: 'btn btn-primary px-8 py-3 text-base' do %>
          <span>Go to Dashboard</span>
          <%= inline_svg_tag 'icons/arrow-right.svg', class: 'size-5 shrink-0' %>
        <% end %>
      <% else %>
        <%= link_to new_registrations_path, class: 'btn btn-primary px-8 py-3 text-base' do %>
          <span>Get Started Free</span>
          <%= inline_svg_tag 'icons/arrow-right.svg', class: 'size-5 shrink-0' %>
        <% end %>
        <%= link_to 'See How It Works', '#how-it-works', class: 'btn btn-transparent px-6 py-3 text-base' %>
      <% end %>
    </div>
  </div>
</section>

<%# ─── HERO SCREENSHOT ─── %>
<section class="px-6 pb-24 md:pb-32">
  <div class="max-w-5xl mx-auto">
    <div class="rounded-2xl border border-neutral-200/60 dark:border-neutral-800/30 shadow-xl dark:shadow-none overflow-hidden">
      <%= image_tag 'dashboard.webp', alt: 'JobJournal dashboard showing weekly stats, upcoming interviews, and follow-up suggestions', class: 'w-full h-auto', loading: 'eager' %>
    </div>
  </div>
</section>

<%# ─── DEMO: DASHBOARD STATS ─── %>
<section id="how-it-works" class="pb-24 md:pb-32 px-6 scroll-mt-20">
  <div class="max-w-5xl mx-auto">
    <p class="text-center text-sm font-semibold tracking-wide uppercase text-primary-600 mb-3">Your dashboard at a glance</p>
    <h2 class="text-center text-[clamp(1.75rem,3.5vw,2.75rem)] font-extrabold tracking-tight text-neutral-900 dark:text-neutral-100 text-balance leading-tight mb-12">
      See where you stand&mdash;instantly.
    </h2>

    <div class="pointer-events-none select-none" aria-hidden="true">
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3">
        <% @demo_stats.each do |stat| %>
          <div class="card flex flex-col">
            <div class="flex items-start justify-between mb-5">
              <p class="font-semibold"><%= stat[:label] %></p>
              <%= inline_svg_tag "icons/#{stat[:icon]}.svg", class: 'size-5 shrink-0' %>
            </div>
            <div class="mt-auto">
              <p class="font-extrabold text-4xl mb-1"><%= stat[:count] %></p>
              <p class="text-xs text-muted"><%= stat[:change] %></p>
            </div>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</section>

<%# ─── THE PROBLEM ─── %>
<section class="py-20 md:py-28 px-6 bg-neutral-50 dark:bg-neutral-900/40">
  <div class="max-w-3xl mx-auto">
    <h2 class="text-[clamp(1.75rem,3.5vw,2.75rem)] font-extrabold tracking-tight text-neutral-900 dark:text-neutral-100 text-balance leading-tight">
      Spreadsheets weren&rsquo;t built&nbsp;for&nbsp;this.
    </h2>

    <div class="mt-8 space-y-5 text-[clamp(1rem,1.2vw,1.125rem)] text-light leading-relaxed">
      <p>
        Everyone says to track your job search in a spreadsheet. It works&mdash;until it doesn&rsquo;t.
      </p>

      <ul class="space-y-3 list-none">
        <li class="flex gap-3 items-center">
          <span class="size-1.5 rounded-full bg-primary-600 shrink-0"></span>
          <span>Spreadsheets don&rsquo;t remind you to follow up, flag stale leads, or tell you which sources are working.</span>
        </li>
        <li class="flex gap-3 items-center">
          <span class="size-1.5 rounded-full bg-primary-600 shrink-0"></span>
          <span>Notes, meeting links, and interview prep end up scattered across apps.</span>
        </li>
        <li class="flex gap-3 items-center">
          <span class="size-1.5 rounded-full bg-primary-600 shrink-0"></span>
          <span>The more applications you add, the harder they are to maintain&mdash;and the less useful they become.</span>
        </li>
      </ul>
    </div>
  </div>
</section>

<%# ─── THE SOLUTION ─── %>
<section class="py-20 md:py-28 px-6">
  <div class="max-w-3xl mx-auto">
    <h2 class="text-[clamp(1.75rem,3.5vw,2.75rem)] font-extrabold tracking-tight text-primary-600 text-balance leading-tight">
      JobJournal flips that&nbsp;script.
    </h2>

    <div class="mt-8 space-y-5 text-[clamp(1rem,1.2vw,1.125rem)] text-light leading-relaxed">
      <p>
        Every opportunity becomes a <span class="text-normal font-semibold">living record</span>. Follow-up suggestions and stale-lead alerts surface on your dashboard automatically. Notes stay attached to the stage they belong to. Insights show which sources actually convert. And universal search with tags and filters finds anything instantly.
      </p>

      <p class="text-neutral-900 dark:text-neutral-100 font-semibold text-[clamp(1.05rem,1.3vw,1.2rem)]">
        Focus on workflows, not rows. JobJournal scales from one dream role to 100 concurrent applications&mdash;without breaking your flow or compromising your privacy.
      </p>
    </div>
  </div>
</section>

<%# ─── SCREENSHOT: JOB LEADS ─── %>
<section class="px-6 pb-24 md:pb-32">
  <div class="max-w-5xl mx-auto">
    <div class="rounded-2xl border border-neutral-200/60 dark:border-neutral-800/30 shadow-lg dark:shadow-none overflow-hidden">
      <%= image_tag 'job_leads.webp', alt: 'JobJournal job leads page showing a grid of tracked opportunities with tags and statuses', class: 'w-full h-auto', loading: 'lazy' %>
    </div>
  </div>
</section>

<%# ─── DEMO: JOB LEADS & INTERVIEWS ─── %>
<section class="py-20 md:py-28 px-6">
  <div class="max-w-6xl mx-auto">
    <p class="text-sm font-semibold tracking-wide uppercase text-primary-600 mb-3">Track every opportunity</p>
    <h2 class="text-[clamp(1.75rem,3.5vw,2.75rem)] font-extrabold tracking-tight text-neutral-900 dark:text-neutral-100 text-balance leading-tight mb-4">
      From first lead to final&nbsp;offer.
    </h2>
    <p class="text-light max-w-2xl text-pretty leading-relaxed mb-12">
      Status. Tags. Notes. A complete timeline. One opportunity, one place, nothing lost. Interviews and notes stay anchored to where they belong&mdash;not buried in separate tabs.
    </p>

    <div class="pointer-events-none select-none" aria-hidden="true">
      <%# ── Job Lead Cards ── %>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-3 mb-8">
        <% @demo_leads.each do |lead| %>
          <%= render lead %>
        <% end %>
      </div>

      <%# ── Interview Cards ── %>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
        <% @demo_interviews.each do |interview| %>
          <%= render interview %>
        <% end %>
      </div>
    </div>
  </div>
</section>

<%# ─── WHY JOBJOURNAL ─── %>
<section class="py-20 md:py-28 px-6 bg-neutral-50 dark:bg-neutral-900/40">
  <div class="max-w-3xl mx-auto text-center">
    <h2 class="text-[clamp(1.75rem,3.5vw,2.75rem)] font-extrabold tracking-tight text-neutral-900 dark:text-neutral-100 text-balance leading-tight">
      Built for you. Not for&nbsp;companies.
    </h2>

    <div class="mt-6 space-y-4 text-[clamp(1rem,1.2vw,1.125rem)] text-light leading-relaxed max-w-2xl mx-auto">
      <p>
        Recruiter tools serve companies. Job boards serve advertisers. JobJournal is built <strong class="text-normal font-semibold">for you</strong>&mdash;you own your data, your narrative, and your next move.
      </p>
    </div>
  </div>
</section>

<%# ─── DEMO: NOTES ─── %>
<section class="py-20 md:py-28 px-6">
  <div class="max-w-6xl mx-auto">
    <p class="text-sm font-semibold tracking-wide uppercase text-primary-600 mb-3">Keep everything in context</p>
    <h2 class="text-[clamp(1.75rem,3.5vw,2.75rem)] font-extrabold tracking-tight text-neutral-900 dark:text-neutral-100 text-balance leading-tight mb-4">
      Notes that stay where they&nbsp;belong.
    </h2>
    <p class="text-light max-w-2xl text-pretty leading-relaxed mb-12">
      Attach notes directly to job leads and interviews. Prep for calls, debrief after meetings, and track offer details, without ever losing context.
    </p>

    <div class="pointer-events-none select-none" aria-hidden="true">
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-3">
        <% @demo_notes.each do |note| %>
          <%= render note, demo: true %>
        <% end %>
      </div>
    </div>
  </div>
</section>

<%# ─── FEATURES ─── %>
<section class="py-20 md:py-28 px-6">
  <div class="max-w-6xl mx-auto">
    <div class="max-w-3xl">
      <h2 class="text-[clamp(1.75rem,3.5vw,2.75rem)] font-extrabold tracking-tight text-neutral-900 dark:text-neutral-100 text-balance leading-tight">
        Core Features
      </h2>
    </div>

    <div class="mt-14 grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
      <%# Feature 1: Job Lead Management %>
      <div class="card">
        <div class="rounded-xl p-2.5 bg-primary-100/70 dark:bg-primary-900/40 inline-flex mb-4">
          <%= inline_svg_tag 'icons/briefcase.svg', class: 'size-5 text-primary-600 dark:text-primary-500' %>
        </div>
        <h3 class="text-lg font-bold text-normal">Job Lead Management</h3>
        <p class="mt-2 text-sm text-light leading-relaxed">
          Capture key details like company, job title, salary, source, and location, while JobJournal keeps track of the timeline, from lead to accepted. Tag opportunities to filter them later and add unlimited notes as you go.
        </p>
      </div>

      <%# Feature 2: Alerts & Reminders %>
      <div class="card">
        <div class="rounded-xl p-2.5 bg-blue-100/70 dark:bg-blue-900/40 inline-flex mb-4">
          <%= inline_svg_tag 'icons/clock.svg', class: 'size-5 text-blue-600 dark:text-blue-500' %>
        </div>
        <h3 class="text-lg font-bold text-normal">Alerts &amp; Reminders</h3>
        <p class="mt-2 text-sm text-light leading-relaxed">
          Upcoming interviews surface automatically. Stale leads you forgot to apply to get flagged. After every application and interview, you'll get a nudge to follow up&mdash;so nothing slips through the cracks.
        </p>
      </div>

      <%# Feature 3: Interview Tracking %>
      <div class="card">
        <div class="rounded-xl p-2.5 bg-purple-100/70 dark:bg-purple-900/40 inline-flex mb-4">
          <%= inline_svg_tag 'icons/interview.svg', class: 'size-5 text-purple-600 dark:text-purple-500' %>
        </div>
        <h3 class="text-lg font-bold text-normal">Interview Tracking</h3>
        <p class="mt-2 text-sm text-light leading-relaxed">
          Log the interviewer's name, date and time, location and call link. Add it to your calendar with the press of a button. Afterward, rate how you felt about the interview, and add unlimited notes for prep, debrief, or feedback.
        </p>
      </div>

      <%# Feature 4: Search & Filters %>
      <div class="card">
        <div class="rounded-xl p-2.5 bg-amber-100/70 dark:bg-amber-900/40 inline-flex mb-4">
          <%= inline_svg_tag 'icons/search.svg', class: 'size-5 text-amber-600 dark:text-amber-500' %>
        </div>
        <h3 class="text-lg font-bold text-normal">Smart Search &amp; Filters</h3>
        <p class="mt-2 text-sm text-light leading-relaxed">
          Find anything instantly&mdash;leads, interviews, notes. Narrow results by tag, status, date, or whether a lead is active or archived. Spend more time making progress, not managing clutter.
        </p>
      </div>

      <%# Feature 5: Insights %>
      <div class="card">
        <div class="rounded-xl p-2.5 bg-rose-100/70 dark:bg-rose-900/40 inline-flex mb-4">
          <%= inline_svg_tag 'icons/star.svg', class: 'size-5 text-rose-600 dark:text-rose-500' %>
        </div>
        <h3 class="text-lg font-bold text-normal">Insights</h3>
        <p class="mt-2 text-sm text-light leading-relaxed">
          See how many leads, applications, and interviews you're hitting each week. Set a weekly goal and track it. Spot which job sources actually convert&mdash;and which ones waste your time.
        </p>
      </div>

      <%# Feature 6: Dashboard Overview %>
      <div class="card">
        <div class="rounded-xl p-2.5 bg-teal-100/70 dark:bg-teal-900/40 inline-flex mb-4">
          <%= inline_svg_tag 'icons/home.svg', class: 'size-5 text-teal-600 dark:text-teal-500' %>
        </div>
        <h3 class="text-lg font-bold text-normal">Dashboard Overview</h3>
        <p class="mt-2 text-sm text-light leading-relaxed">
          Your entire job search in one view. Weekly stats, progress toward your application goal, smart suggestions, upcoming interviews, and recent notes&mdash;all in one place so you can pick up exactly where you left off.
        </p>
      </div>
    </div>
  </div>
</section>

<%# ─── PRIVACY ─── %>
<section class="py-20 md:py-28 px-6 bg-neutral-50 dark:bg-neutral-900/40">
  <div class="max-w-3xl mx-auto text-center">
    <div class="rounded-full p-4 bg-primary-100/70 dark:bg-primary-900/40 inline-flex mb-6">
      <%= inline_svg_tag 'icons/security.svg', class: 'size-8 text-primary-600 dark:text-primary-500' %>
    </div>

    <h2 class="text-[clamp(1.75rem,3.5vw,2.75rem)] font-extrabold tracking-tight text-neutral-900 dark:text-neutral-100 text-balance leading-tight">
      Private &amp; Secure
    </h2>

    <div class="mt-6 space-y-4 text-[clamp(1rem,1.2vw,1.125rem)] text-light leading-relaxed max-w-2xl mx-auto">
      <p>
        Your job search data is <em>yours alone</em>. JobJournal is <strong class="text-normal font-semibold">privacy-first</strong> by design&mdash;no third-party sharing, no tracking, no recruiter analytics. Everything is scoped to your account, and you can delete it all at any time.
      </p>
    </div>
  </div>
</section>

<%# ─── FINAL CTA ─── %>
<section class="py-20 md:py-28 px-6">
  <div class="max-w-3xl mx-auto text-center">
    <h2 class="text-[clamp(1.75rem,3.5vw,2.75rem)] font-extrabold tracking-tight text-neutral-900 dark:text-neutral-100 text-balance leading-tight">
      Ready to ditch the&nbsp;spreadsheet?
    </h2>

    <p class="mt-4 text-[clamp(1rem,1.2vw,1.125rem)] text-light leading-relaxed">
      Stay organized, stay motivated, and stay private with JobJournal.
    </p>

    <div class="mt-10 flex flex-wrap items-center justify-center gap-4">
      <% if authenticated? %>
        <%= link_to dashboard_path, data: { turbo: false }, class: 'btn btn-primary px-8 py-3 text-base' do %>
          <span>Go to Dashboard</span>
          <%= inline_svg_tag 'icons/arrow-right.svg', class: 'size-5 shrink-0' %>
        <% end %>
      <% else %>
        <%= link_to new_registrations_path, class: 'btn btn-primary px-10 py-3.5 text-base' do %>
          <span>Start Tracking Your Search</span>
          <%= inline_svg_tag 'icons/arrow-right.svg', class: 'size-5 shrink-0' %>
        <% end %>
      <% end %>
    </div>
  </div>
</section>

<%# ─── FOOTER ─── %>
<footer class="py-10 px-6 border-t border-neutral-200/60 dark:border-neutral-800/40">
  <div class="max-w-6xl mx-auto flex flex-col sm:flex-row items-center justify-between gap-4">
    <div class="flex items-center gap-1.5 text-primary-600">
      <%= inline_svg_tag 'icons/note-filled.svg', class: 'size-5 shrink-0' %>
      <span class="text-base font-extrabold tracking-tight">JobJournal</span>
    </div>

    <p class="text-sm text-muted">
      Created with ❤️ by <%= link_to 'Braden Roth', 'https://bradenroth.com', target: '_blank', rel: 'noopener noreferrer', class: 'text-light hover:text-primary-600 transition-colors duration-150' %>
    </p>
  </div>
</footer>
