<% content_for :title, 'Interviews' %>

<div class="sm:w-7/8 w-full mx-auto">
  <div class="mb-4 flex flex-wrap gap-2 items-center justify-between">
    <%= link_to dashboard_path, class: 'btn btn-sm btn-secondary btn-muted gap-1.5 [view-transition-name:back-btn]' do %>
      <%= icon 'arrow-left', class: 'size-3.5 shrink-0' %>
      <span>Back Home</span>
    <% end %>
  </div>

  <div class="mb-4">
    <h1 class="heading">
      Interviews
    </h1>
    <span class="ml-1 text-sm text-muted font-normal align-middle [view-transition-name:interview-count]">
      <%= interview_count_text @interviews.size, type: @selected_interview_type %>
    </span>
  </div>

  <%= render 'filters' %>

  <div id="interviews" class="@container">
    <% if @interviews.any? %>
      <div class="<%= collection_layout_class_names :interviews_display, count: @interviews.size, size: :large %>">
        <%= render @interviews %>
      </div>
    <% else %>
      <div class="empty-state">
        No interviews found.
      </div>
    <% end %>
  </div>
</div>
