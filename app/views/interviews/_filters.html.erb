<div id="interview-filters" class="my-4 space-y-1">
  <div class="flex flex-wrap items-center gap-1">
    <%= link_to interviews_path(scheduled: nil), class: 'inline-block', style: "view-transition-name: all-interviews" do %>
      <span class="tag tag-filter <%= 'tag-selected' unless params[:scheduled].present? %>">All</span>
    <% end %>

    <%= link_to interviews_path(scheduled: params[:scheduled] == 'upcoming' ? nil : 'upcoming'), class: 'inline-block', style: "view-transition-name: upcoming-interviews" do %>
      <span class="tag tag-filter tag-interview <%= 'tag-selected' if params[:scheduled] == 'upcoming' %>">
        <span>Upcoming</span>
        <%= icon 'x-mini' if params[:scheduled] == 'upcoming' %>
      </span>
    <% end %>

    <%= link_to interviews_path(scheduled: params[:scheduled] == 'completed' ? nil : 'completed'), class: 'inline-block', style: "view-transition-name: completed-interviews" do %>
      <span class="tag tag-filter tag-accepted <%= 'tag-selected' if params[:scheduled] == 'completed' %>">
        <span>Completed</span>
        <%= icon 'x-mini' if params[:scheduled] == 'completed' %>
      </span>
    <% end %>
  </div>
</div>
