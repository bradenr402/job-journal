<% content_for :title, 'Notes' %>

<div class="sm:w-7/8 w-full mx-auto">
  <div class="mb-4 flex flex-wrap gap-2 items-center justify-between">
    <%= link_to dashboard_path, class: 'btn btn-sm btn-secondary btn-muted gap-1.5 [view-transition-name:back-btn]' do %>
      <%= icon 'arrow-left', class: 'size-3.5 shrink-0' %>
      <span>Back Home</span>
    <% end %>
  </div>

  <div class="mb-4">
    <h1 class="heading">
      Notes
    </h1>
    <span class="ml-1 text-sm text-muted font-normal align-middle [view-transition-name:note-count]">
      <%= note_count_text @notes.size, type: @selected_note_type, notable: params[:notable_type] %>
    </span>
  </div>

  <%= render 'filters' %>

  <div id="notes" class="@container">
    <% if @notes.any? %>
      <div class="<%= collection_layout_class_names :notes_display, count: @notes.size, size: :medium %>">
        <%= render @notes %>
      </div>
    <% else %>
      <div class="empty-state">
        No notes found.
      </div>
    <% end %>
  </div>
</div>
