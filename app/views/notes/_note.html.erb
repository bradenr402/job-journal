<%
  note_page = current_page?(note_path(note))
  display_title = note_page || current_page?(notes_path) || current_page?(dashboard_path) || current_page?(search_path) || @demo

  note_title = note.title if display_title
%>

<div id="<%= dom_id note %>" class="relative <%= item_layout_class_names :notes_display %> flex flex-col" style="view-transition-name: note-<%= note.id %>;">
  <% unless note_page || @demo %>
    <%= link_to "", note, class: "blanket-link", data: { turbo_frame: "_top" }, aria: { label: "View note" } %>
  <% end %>

  <% if display_title %>
    <p class="text-xs font-semibold mb-2 inline-flex items-start gap-1">
      <% if note.notable.is_a?(Interview) %>
        <%= icon 'interview-filled', class: 'size-3 shrink-0 mt-0.5' %>
      <% elsif note.notable.is_a?(JobLead) %>
        <%= icon 'briefcase-filled', class: 'size-3 shrink-0 mt-0.5' %>
      <% end %>
      <%= note_title %>
    </p>
  <% end %>

  <div class="<%= 'h-full grow max-h-24' unless note_page %> overflow-hidden relative">
    <% note_content = note_page ? markdown_to_html(note.content) : note.content %>
    <% note_classes = note_page ? 'prose' : 'whitespace-break-spaces text-light line-clamp-4 select-none' %>

    <%= content_tag(:div, note_content, class: note_classes) %>
  </div>

  <% if note_page %>
    <div class="text-xs text-muted text-right flex items-center justify-end gap-1">
      <%= icon 'quill', class: 'size-3.5 shrink-0' %>
      <%== note.edited? ? "Updated: #{local_time_short note.updated_at}" : "Created: #{local_time_short note.created_at}" %>
    </div>
  <% end %>
</div>
