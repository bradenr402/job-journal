<% content_for :title, "#{@job_lead.title} @ #{@job_lead.company}" %>

<div class="md:w-7/8 w-full mx-auto">
  <div class="mb-4 flex flex-wrap gap-2 items-center justify-between">
    <%= link_to job_leads_path, class: 'btn btn-sm btn-secondary btn-muted gap-1.5 [view-transition-name:back-btn]' do %>
      <%= icon 'arrow-left', class: 'size-3.5 shrink-0' %>
      <span>Back to Job Leads</span>
    <% end %>
  </div>

  <%= render @job_lead %>

  <%= render 'status_buttons', job_lead: @job_lead %>

  <%= render 'shared/notes', notable: @job_lead, notes: @notes %>

  <!-- Interviews -->
  <div class="mt-12 @container">
    <div class="flex items-center justify-between mb-4">
      <h2 class="subheading">Interviews</h2>
      <% if @job_lead.interview? %>
        <%= link_to new_interview_path(job_lead_id: @job_lead.id), class: 'btn btn-sm btn-primary' do %>
          <%= icon 'interview', class: 'size-4 shrink-0' %>
          <span>New Interview</span>
        <% end %>
      <% end %>
    </div>
    <% if @interviews.any? %>
      <div class="<%= collection_layout_class_names :interviews_display, count: @interviews.size, size: :large %>">
        <%= render @interviews %>
      </div>
    <% else %>
      <div class="empty-state">
        No interviews yet.
      </div>
    <% end %>
  </div>
</div>
